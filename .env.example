# Copy this file to .env and fill in your values
# Never commit .env to git

# App secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=your_secret_key_here

# Google Drive integration — required for data persistence on Railway
# All data (holdings CSVs, pledge config, user accounts, history) is
# read from and written to the Drive folder below.
# On Railway: set these in Project → Variables, not in this file.
# GOOGLE_SERVICE_ACCOUNT_JSON=<paste full JSON of the GCP service account key>
# GOOGLE_DRIVE_FOLDER_ID=<folder ID from the Drive folder URL>

# Optional: override local data cache directory (gitignored)
# DATA_DIR=./data
